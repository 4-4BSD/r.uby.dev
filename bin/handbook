#!/usr/bin/env ruby
# frozen_string_literal: true

def usage
  warn <<~USAGE
    #{$0} command [OPTIONS]

    commands:
      create-database   new SQLite3 database
      web               serve a HTTP search API
  USAGE
end

def main(argv)
  File.realpath File.join(__dir__, "..", "libexec")

  case argv[0]
  when nil then usage
  when "web"
    Process.spawn File.join("libexec", "rubydoc", argv[0]), *argv[1..]
    Process.wait
  when "create-database"
    Process.spawn File.join("libexec", "rubydoc", argv[0]), *argv[1..]
    Process.wait
  else usage
  end
end
main(ARGV)
